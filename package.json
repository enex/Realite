{
  "name": "realite-web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build --webpack",
    "start": "next start",
    "start:prod": "bun run db:migrate:locked && next start",
    "lint": "bun run typecheck",
    "typecheck": "./node_modules/.bin/next typegen && tsc --noEmit --incremental false",
    "test": "bun test",
    "check": "bun run typecheck && bun run test",
    "db:generate": "drizzle-kit generate --config=drizzle.config.ts",
    "db:migrate": "bun run db:migrate:raw",
    "db:migrate:locked": "bun run scripts/run-migrations.ts",
    "db:migrate:raw": "drizzle-kit migrate --config=drizzle.config.ts",
    "db:studio": "drizzle-kit studio --config=drizzle.config.ts",
    "db:seed": "bun run scripts/seed-dev-users.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1040.0",
    "@aws-sdk/s3-request-presigner": "^3.1040.0",
    "@better-auth/core": "1.5.5",
    "@better-auth/oauth-provider": "1.5.5",
    "@kubiks/otel-drizzle": "^2.1.0",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/api-logs": "^0.213.0",
    "@opentelemetry/context-async-hooks": "^2.6.0",
    "@opentelemetry/exporter-logs-otlp-http": "^0.213.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.213.0",
    "@opentelemetry/instrumentation": "^0.213.0",
    "@opentelemetry/instrumentation-http": "^0.213.0",
    "@opentelemetry/resources": "^2.6.0",
    "@opentelemetry/sdk-logs": "^0.213.0",
    "@opentelemetry/sdk-trace-base": "^2.6.0",
    "@opentelemetry/sdk-trace-node": "^2.6.0",
    "@opentelemetry/semantic-conventions": "^1.40.0",
    "@phosphor-icons/react": "^2.1.10",
    "@radix-ui/react-dialog": "^1.1.15",
    "@serwist/next": "^9.5.6",
    "@takumi-rs/image-response": "^0.71.7",
    "@tanstack/react-query": "^5.90.21",
    "better-auth": "1.5.5",
    "better-call": "1.3.2",
    "drizzle-orm": "^0.45.1",
    "heic2any": "^0.0.4",
    "marked": "^17.0.4",
    "next": "^16.1.6",
    "next-themes": "^0.4.6",
    "postgres": "^3.4.8",
    "posthog-js": "^1.360.0",
    "qrcode": "^1.5.4",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-easy-crop": "^5.5.7",
    "sonner": "^2.0.7",
    "uuid": "^13.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.1",
    "@types/google.maps": "^3.58.1",
    "@types/node": "^25.4.0",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.4.27",
    "dotenv": "^17.3.1",
    "drizzle-kit": "^0.31.9",
    "postcss": "^8.5.8",
    "serwist": "^9.5.6",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.9.3"
  },
  "packageManager": "bun@1.2.2"
}
