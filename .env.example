BETTER_AUTH_URL=http://localhost:3000
BETTER_AUTH_SECRET=change-this-to-a-long-random-string

# Admin-Dashboard unter /admin — mindestens eine Option:
# – REALITE_ADMIN_EMAILS: kommagetrennte Better-Auth-Konten mit Zugang (z. B. "du@firma.de, anderer@firma.de")
# – REALITE_ADMIN_SECRET: mindestens 24 Zeichen; optional für Notfall ohne Realite-Login (Cookie, begrenzte Gültigkeit)
# REALITE_ADMIN_EMAILS=
# REALITE_ADMIN_SECRET=
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/realite
NEXT_PUBLIC_POSTHOG_KEY=phc_your_posthog_project_api_key
NEXT_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com

# S3-compatible object storage for persisted profile images
S3_BUCKET=realite-dev
# Cloudflare R2: often "auto". OVH: datacenter slug (e.g. sbg for s3.sbg.io.cloud.ovh.net); if S3_REGION is unset or "auto", it is inferred from an OVH endpoint hostname.
S3_REGION=auto
S3_ENDPOINT=https://s3.example.com
S3_ACCESS_KEY=your-access-key
S3_SECRET_ACCESS_KEY=your-secret-key
S3_PUBLIC_BASE_URL=https://cdn.example.com/realite-dev
# Private bucket: browsers get time-limited read URLs (default on). Set to "false" when objects are public (e.g. bucket policy / ACL).
# S3_PROFILE_IMAGE_READ_SIGNED_URL=false
# Max presigned TTL in seconds (capped at 604800).
# S3_PROFILE_IMAGE_PRESIGNED_TTL_SECONDS=604800
# If your provider supports canned ACL on PutObject: public-read without changing bucket policy.
# S3_PROFILE_IMAGE_OBJECT_ACL_PUBLIC_READ=true
# S3_FORCE_PATH_STYLE=true

# Optional: Google Maps JavaScript API (Places) für Ortssuche beim Event anlegen — Key mit HTTP-Referrer einschränken
# NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# OpenTelemetry Traces (Tempo / OTLP) – Spans werden nur bei gesetzter URL exportiert
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318/v1/traces
# OTLP_URL=http://localhost:5080/api/default/v1/traces
# OTLP_SERVICE_NAME=realite-web
# OTLP_AUTH=base64-user:password
